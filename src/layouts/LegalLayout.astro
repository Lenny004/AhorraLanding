---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = `${title} de Ahorra Sin Líos. Información legal sobre el uso del sitio web y el tratamiento de datos.` } = Astro.props;
---

<BaseLayout title={`${title} | Ahorra Sin Líos`} description={description} ogType="article">
  <Header />
  <main class="legal-page">
    <div class="container">
      <slot />
    </div>
  </main>
  <Footer />
</BaseLayout>
