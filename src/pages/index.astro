---
import BaseLayout from '../layouts/BaseLayout.astro';
import Brand from '../components/Brand.astro';
import Footer from '../components/Footer.astro';
import { verticalLabels, verticalPaths } from '../lib/vertical';

const options = [
  {
    vertical: 'energy' as const,
    href: verticalPaths.energy,
    label: verticalLabels.energy,
    description: 'Comparamos tarifas de luz y gas, revisamos tu factura y gestionamos el cambio por ti.',
    icon: 'bolt',
    accent: 'hub__card--energy',
  },
  {
    vertical: 'telecom' as const,
    href: verticalPaths.telecom,
    label: verticalLabels.telecom,
    description: 'Fibra y móvil ajustados a tu consumo real, sin servicios de más ni letra pequeña.',
    icon: 'wifi',
    accent: 'hub__card--telecom',
  },
];
---

<BaseLayout
  title="Ahorra Sin Líos — Elige tu servicio"
  description="Comparador gratuito de luz, gas, internet y móvil. Elige qué quieres optimizar y empieza a ahorrar sin líos."
  keywords="Ahorra Sin Líos, ahorrar facturas, comparar luz gas, fibra móvil, comparador tarifas"
>
  <header class="hub__header">
    <div class="container hub__header-inner">
      <a href="/" class="brand" aria-label="Ahorra Sin Líos">
        <Brand />
      </a>
    </div>
  </header>

  <main class="hub">
    <div class="hub__bg" aria-hidden="true">
      <div class="hub__bg-blob hub__bg-blob--top"></div>
      <div class="hub__bg-blob hub__bg-blob--bottom"></div>
    </div>

    <div class="container hub__inner">
      <header class="hub__intro" data-reveal>
        <span class="label-s hub__kicker">Comparador gratuito</span>
        <h1 class="display-xl hub__title">
          ¿Qué quieres <span class="text-gradient">optimizar hoy?</span>
        </h1>
        <p class="body-lg text-muted hub__lead">
          Comparamos luz, gas, fibra y móvil por ti. Sin coste ni compromiso — elige un servicio y descubre cuánto puedes ahorrar.
        </p>
      </header>

      <div class="hub__grid">
        {options.map((option, i) => (
          <a
            href={option.href}
            class={`hub__card card-lift ${option.accent}`}
            data-reveal
            style={`--reveal-delay: ${i * 100}ms`}
          >
            <div class="hub__card-icon">
              <span class="material-symbols-outlined">{option.icon}</span>
            </div>
            <h2 class="headline-lg hub__card-title">{option.label}</h2>
            <p class="body-md text-muted hub__card-text">{option.description}</p>
            <span class="label-s hub__card-cta">
              Empezar
              <span class="material-symbols-outlined hub__card-arrow" aria-hidden="true">arrow_forward</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer contactHref="/luz-gas#contacto" />
</BaseLayout>

<style>
  .hub__header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(247, 247, 244, 0.92);
    backdrop-filter: blur(0.75rem);
    border-bottom: 1px solid rgba(226, 226, 222, 0.72);
    box-shadow: var(--shadow-soft);
  }

  .hub__header-inner {
    display: flex;
    align-items: center;
    padding-block: 1rem;
  }

  .hub {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 5rem);
    padding-block: 6rem 4rem;
    background: var(--color-bg);
  }

  .hub__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hub__bg-blob {
    position: absolute;
    border-radius: var(--radius-full);
    filter: blur(4rem);
    opacity: 0.55;
  }

  .hub__bg-blob--top {
    top: -10%;
    right: -8%;
    width: 55%;
    height: 80%;
    background: linear-gradient(to bottom left, rgba(121, 184, 42, 0.18), transparent);
  }

  .hub__bg-blob--bottom {
    bottom: -8%;
    left: -8%;
    width: 48%;
    height: 50%;
    background: linear-gradient(to top right, rgba(231, 184, 46, 0.22), transparent);
  }

  .hub__inner {
    position: relative;
    z-index: 1;
  }

  .hub__intro {
    max-width: 40rem;
    margin-bottom: 3rem;
  }

  .hub__kicker {
    display: inline-block;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-full);
    color: var(--color-night);
    background: var(--color-cream);
    border: 1px solid var(--color-border);
  }

  .hub__title {
    margin-bottom: 1rem;
    color: var(--color-night);
  }

  .hub__lead {
    max-width: 34rem;
  }

  .hub__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .hub__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 2rem;
    border-radius: var(--radius-brand);
    background: #ffffff;
    border: 1px solid var(--color-border);
    color: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .hub__card:hover {
    border-color: rgba(121, 184, 42, 0.35);
  }

  .hub__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-full);
    color: var(--color-gold);
    background: var(--color-cream);
  }

  .hub__card-icon .material-symbols-outlined {
    font-size: var(--size-lg);
    font-variation-settings: 'FILL' 1;
  }

  .hub__card--telecom .hub__card-icon {
    color: var(--color-night);
    background: rgba(231, 184, 46, 0.28);
  }

  .hub__card-title {
    color: var(--color-night);
  }

  .hub__card-text {
    flex: 1;
  }

  .hub__card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-green);
    font-weight: 700;
  }

  .hub__card-arrow {
    font-size: var(--size-m);
    transition: translate 0.2s ease;
  }

  .hub__card:hover .hub__card-arrow {
    translate: 0.25rem 0;
  }

  @media (min-width: 48rem) {
    .hub__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .hub__intro {
      margin-bottom: 4rem;
    }
  }
</style>
