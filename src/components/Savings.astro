---
import type { Vertical } from '../lib/vertical';

interface Props {
  vertical?: Vertical;
}

const { vertical = 'energy' } = Astro.props;

const copy = {
  energy: {
    lead: 'Nuestros usuarios ahorran de media hasta 300€ anuales optimizando luz y gas.',
    pill: 'Al año en energía',
  },
  telecom: {
    lead: 'Nuestros usuarios ahorran de media hasta 200€ anuales optimizando fibra y móvil.',
    pill: 'Al año en conectividad',
  },
}[vertical];

const amounts = { energy: '300€', telecom: '200€' };
---
<section class="savings section">
  <div class="savings__glow" aria-hidden="true"></div>
  <div class="container savings__inner" data-reveal>
    <h2 class="display-xl savings__title">¿Cuánto podrías ahorrar al año?</h2>
    <p class="body-lg text-inverse savings__lead">
      {copy.lead}
    </p>

    <div class="savings__card">
      <span class="label-xs savings__label">Ahorro medio estimado</span>
      <span class="savings__amount">{amounts[vertical]}</span>
      <span class="label-s savings__pill">{copy.pill}</span>
    </div>
  </div>
</section>

<style>
  .savings {
    position: relative;
    overflow: hidden;
    color: #ffffff;
    background: var(--color-night);
  }

  .savings__glow {
    position: absolute;
    top: 50%;
    right: -10rem;
    width: 34rem;
    height: 34rem;
    border-radius: var(--radius-full);
    background: rgba(121, 184, 42, 0.24);
    filter: blur(6rem);
    translate: 0 -50%;
  }

  .savings__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .savings__title {
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .savings__lead {
    max-width: 42rem;
    margin-bottom: 3rem;
  }

  .savings__card {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    border-radius: var(--radius-brand);
    color: var(--color-night);
    background: #ffffff;
    box-shadow: var(--shadow-lift);
  }

  .savings__label {
    margin-bottom: 0.35rem;
    color: var(--color-muted-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .savings__amount {
    margin-bottom: 0.75rem;
    color: var(--color-green);
    font-size: clamp(4rem, 12vw, 6rem);
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.04em;
  }

  .savings__pill {
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-full);
    color: var(--color-night);
    background: var(--color-gold);
  }
</style>
