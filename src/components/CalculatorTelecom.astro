---
const benefits = [
  'Porcentaje de ahorro estimado',
  'Ahorro en euros al mes y al año',
  'Mejor tarifa disponible para ti',
];

const telecomTypes = [
  { label: 'Solo móvil', value: 'solo-movil' },
  { label: 'Solo fibra', value: 'solo-fibra' },
  { label: 'Móvil + fibra', value: 'movil-fibra' },
];

const mobileLineOptions = ['1', '2', '3', '4 o más'];

const dataUsageOptions = [
  'Menos de 10 GB',
  '10-30 GB',
  '30-50 GB',
  'Más de 50 GB',
  'No lo sé',
];

const connectionOptions = ['Fibra', 'ADSL', 'No tengo en casa'];

const fiberSpeedOptions = [
  'Menos de 100 Mb',
  '100-300 Mb',
  '600 Mb',
  '1 Gb',
  'No lo sé',
];

const providers = [
  'Movistar', 'Vodafone', 'Orange', 'MásMóvil', 'Digi', 'Yoigo', 'Otro',
];

const permanenceOptions = ['Sí', 'No', 'No lo sé'];

const crmEndpoint = import.meta.env.PUBLIC_CRM_LANDING_LEADS_ENDPOINT ?? 'https://TU_DOMINIO_CRM/PTR-Sales/api/public/api_landing_leads.php?action=create';
const crmApiKey = import.meta.env.PUBLIC_AHORRA_LANDING_API_KEY ?? '';
---

<section class="calculator section" id="calculadora">
  <div class="container">
    <header class="section-header" data-reveal>
      <h2 class="display-xl">Comparador</h2>
      <p class="body-lg text-muted">Móvil e internet, cuánto puedes ahorrar con la mejor tarifa.</p>
    </header>

    <div
      class="calculator-panel card-lift"
      data-calc-root
      data-endpoint={crmEndpoint}
      data-api-key={crmApiKey}
      data-source="ahorrasinlios"
      data-reveal
    >
      <!-- Intro -->
      <div class="calc-view" data-calc-view="intro">
        <span class="calc-badge label-xs">Comparador gratuito</span>
        <h3 class="calc-title display-xl">¿Cuánto podrías ahorrar en tu factura de móvil e internet?</h3>
        <p class="calc-lead body-lg text-muted">
          Responde unas preguntas y descubre si estás pagando de más — y qué tarifa te conviene.
        </p>
        <p class="calc-highlight label-s">
          Ahorro medio: <strong>25€/mes</strong>
        </p>

        <ul class="calc-benefits">
          {benefits.map((item) => (
            <li class="calc-benefit">
              <span class="material-symbols-outlined calc-benefit-icon" aria-hidden="true">check_circle</span>
              {item}
            </li>
          ))}
        </ul>

        <button type="button" class="calc-cta btn-primary" data-calc-start>
          <span class="calc-cta-main">Empezar el análisis</span>
          <span class="calc-cta-sub">Gratis · Sin compromiso · 2 minutos</span>
        </button>
      </div>

      <!-- Wizard -->
      <div class="calc-view calc-view--wizard" data-calc-view="wizard" hidden>
        <div class="calc-progress" aria-hidden="true">
          <div class="calc-progress-fill" data-calc-progress></div>
        </div>

        <div class="calc-step" data-calc-step="0">
          <h3 class="calc-step-title display-xl">¿Qué quieres analizar?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {telecomTypes.map((opt) => (
              <label class="calc-option"><input type="radio" name="telecomType" value={opt.value} /><span class="calc-option-ui"></span>{opt.label}</label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="1" hidden>
          <h3 class="calc-step-title display-xl">¿Cuánto pagas ahora al mes?</h3>
          <p class="calc-step-sub body-lg text-muted">Mira tu última factura</p>
          <input class="calc-input" type="number" name="monthlyBill" min="1" placeholder="Ej: 55" inputmode="decimal" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="2" hidden>
          <h3 class="calc-step-title display-xl">¿Cuántas líneas móviles?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {mobileLineOptions.map((label) => (
              <label class="calc-option"><input type="radio" name="mobileLines" value={label} /><span class="calc-option-ui"></span>{label}</label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="3" hidden>
          <h3 class="calc-step-title display-xl">¿Cuántos GB usas al mes por línea?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {dataUsageOptions.map((label) => {
              const val = label.toLowerCase().replace(/\s+/g, '-').replace(/[áéíóú]/g, (c) => ({ 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u' })[c] || c);
              return (
                <label class="calc-option"><input type="radio" name="dataUsageGb" value={val} /><span class="calc-option-ui"></span>{label}</label>
              );
            })}
          </div>
        </div>

        <div class="calc-step" data-calc-step="4" hidden>
          <h3 class="calc-step-title display-xl">¿Tienes fibra o ADSL?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {connectionOptions.map((label) => {
              const val = label.toLowerCase().replace(/\s+/g, '-');
              return (
                <label class="calc-option"><input type="radio" name="connectionType" value={val} /><span class="calc-option-ui"></span>{label}</label>
              );
            })}
          </div>
        </div>

        <div class="calc-step" data-calc-step="5" hidden>
          <h3 class="calc-step-title display-xl">¿Qué velocidad de bajada tienes?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {fiberSpeedOptions.map((label) => {
              const val = label.toLowerCase().replace(/\s+/g, '-').replace(/[áéíóú]/g, (c) => ({ 'á': 'a', 'é': 'e', 'í': 'i', 'ó': 'o', 'ú': 'u' })[c] || c);
              return (
                <label class="calc-option"><input type="radio" name="fiberSpeed" value={val} /><span class="calc-option-ui"></span>{label}</label>
              );
            })}
          </div>
        </div>

        <div class="calc-step" data-calc-step="6" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu operador actual?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {providers.map((label) => (
              <label class="calc-option"><input type="radio" name="provider" value={label} /><span class="calc-option-ui"></span>{label}</label>
            ))}
          </div>
        </div>

        <div class="calc-step" data-calc-step="7" hidden>
          <h3 class="calc-step-title display-xl">¿Tienes permanencia activa?</h3>
          <p class="calc-step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calc-options" role="radiogroup">
            {permanenceOptions.map((label) => {
              const val = label.toLowerCase().replace(/\s+/g, '-');
              return (
                <label class="calc-option"><input type="radio" name="hasPermanence" value={val} /><span class="calc-option-ui"></span>{label}</label>
              );
            })}
          </div>
        </div>

        <div class="calc-step" data-calc-step="8" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu código postal?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu código postal</p>
          <input class="calc-input" type="text" name="postalCode" placeholder="Ej: 28001" maxlength="5" inputmode="numeric" pattern="[0-9]{5}" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="9" hidden>
          <h3 class="calc-step-title display-xl">¿Cómo te llamas?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu nombre completo</p>
          <p class="calc-privacy-note body-md">
            Para enviarte el resultado personalizado, necesitamos tu contacto. Solo guardaremos tus datos en nuestro CRM si aceptas la política de privacidad.
          </p>
          <input class="calc-input" type="text" name="firstName" placeholder="Nombre" autocomplete="given-name" />
          <input class="calc-input" type="text" name="lastName" placeholder="Introduce tu apellido" autocomplete="family-name" />
          <button type="button" class="calc-continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calc-step" data-calc-step="10" hidden>
          <h3 class="calc-step-title display-xl">¿Cuál es tu número de teléfono?</h3>
          <p class="calc-step-sub body-lg text-muted">Introduce tu teléfono</p>
          <input class="calc-input" type="tel" name="phone" placeholder="600 00 00 00" autocomplete="tel" />
          <label class="calc-consent">
            <input type="checkbox" name="privacy" />
            <span class="body-md text-muted">
              Acepto que Ahorra Sin Líos trate mis datos personales y los registre en su CRM de gestión comercial para contactarme con la mejor oferta. Puedo retirar mi consentimiento en cualquier momento. <a href="/privacidad">Política de privacidad</a>.
            </span>
          </label>
          <button type="button" class="calc-continue btn-primary" data-calc-finish>Continuar</button>
        </div>

        <div class="calc-nav">
          <button type="button" class="calc-back btn-secondary" data-calc-back hidden>
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
            Atrás
          </button>
        </div>
      </div>

      <!-- Results -->
      <div class="calc-view calc-view--results" data-calc-view="results" hidden>
        <div class="calc-result-card">
          <p class="calc-result-label label-xs">Resultado del análisis</p>
          <p class="calc-result-percent display-xl" data-calc-result-percent>30%</p>
          <p class="calc-result-desc body-lg">de ahorro estimado en tu factura</p>
          <p class="calc-result-badge label-s" data-calc-result-savings>16,50€/mes · 198,00€/año</p>

          <div class="calc-result-cta-wrap">
            <p class="body-md text-muted">Encuentra la tarifa que mejor encaja contigo hoy</p>
            <a href="#contacto" class="calc-cta btn-primary" data-calc-result-cta>
              <span class="calc-cta-main">Quiero pagar menos →</span>
              <span class="calc-cta-sub">Gratis · Sin compromiso · 5 minutos</span>
            </a>
          </div>
        </div>

        <p class="calc-comparison-label label-xs text-muted-soft">Factura actual</p>
        <div class="calc-comparison card-lift">
          <div class="calc-comparison-row">
            <div>
              <p class="label-xs text-muted-soft">Pagas ahora</p>
              <p class="calc-comparison-bad label-xs">✕ Tarifa sin optimizar</p>
            </div>
            <p class="calc-comparison-amount" data-calc-result-current>55,00€</p>
          </div>
          <div class="calc-comparison-bar">
            <span class="material-symbols-outlined" aria-hidden="true">south</span>
            Cambiando de tarifa
          </div>
          <div class="calc-comparison-row calc-comparison-row--new">
            <div>
              <p class="label-s calc-comparison-good">Tu nueva factura</p>
              <ul class="calc-comparison-perks">
                <li>✓ Fibra optimizada</li>
                <li>✓ Móvil ajustado a tu consumo</li>
                <li>✓ Sin permanencia</li>
              </ul>
            </div>
            <p class="calc-comparison-amount calc-comparison-amount--new" data-calc-result-new>38,50€</p>
          </div>
        </div>

        <p class="calc-comparison-label label-xs text-muted-soft">Por qué estás pagando de más</p>
        <div class="calc-why card-lift">
          <p class="body-md"><span class="calc-why-x" aria-hidden="true">✕</span> <strong>Las ofertas de bienvenida caducan.</strong> Si no cambias cada 12-24 meses, pagas de más.</p>
          <p class="body-md"><span class="calc-why-x" aria-hidden="true">✕</span> <strong>Pagas por servicios que no usas.</strong> Líneas, GB o canales que podrías recortar.</p>
        </div>

        <button type="button" class="calc-restart btn-secondary" data-calc-restart>Volver a calcular</button>
      </div>
    </div>
  </div>
</section>

<script>
  import { initTelecomCalculator } from '../scripts/telecom-calculator';

  initTelecomCalculator();
</script>

<style>
  .calculator {
    scroll-margin-top: 5rem;
    background: var(--color-bg);
  }

  .calculator-panel {
    max-width: 36rem;
    margin-inline: auto;
    padding: 2.5rem 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid rgba(226, 226, 222, 0.72);
    text-align: center;
  }

  .calc-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .calc-view[hidden],
  .calc-step[hidden] {
    display: none;
  }

  .calc-badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(121, 184, 42, 0.45);
    color: var(--color-green);
    background: rgba(121, 184, 42, 0.08);
  }

  .calc-title {
    font-size: calc(var(--size-xl) * 0.72);
  }

  .calc-lead {
    max-width: 28rem;
  }

  .calc-highlight {
    color: var(--color-green);
  }

  .calc-benefits {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    list-style: none;
  }

  @media (min-width: 40rem) {
    .calc-benefits {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  .calc-benefit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    font-size: var(--size-xs);
    font-weight: 600;
    text-align: left;
  }

  .calc-benefit-icon {
    font-size: 1.25rem;
    color: var(--color-green);
  }

  .calc-cta {
    flex-direction: column;
    width: 100%;
    padding-block: 1.1rem;
    gap: 0.25rem;
  }

  .calc-cta-main {
    font-size: var(--size-s);
    font-weight: 700;
  }

  .calc-cta-sub {
    font-size: var(--size-xs);
    font-weight: 500;
    opacity: 0.9;
  }

  .calc-view--wizard {
    width: 100%;
    gap: 2rem;
  }

  .calc-progress {
    width: 100%;
    height: 0.25rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-soft);
    overflow: hidden;
  }

  .calc-progress-fill {
    height: 100%;
    width: 0;
    border-radius: inherit;
    background: var(--color-green);
    transition: width 0.35s ease;
  }

  .calc-step {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.25rem;
    width: 100%;
  }

  .calc-step-title {
    font-size: calc(var(--size-xl) * 0.65);
    text-align: center;
  }

  .calc-step-sub {
    text-align: center;
    margin-top: -0.5rem;
  }

  .calc-options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .calc-option {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(121, 184, 42, 0.35);
    background: #ffffff;
    cursor: pointer;
    font-weight: 600;
    text-align: left;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .calc-option:hover {
    border-color: var(--color-green);
  }

  .calc-option:has(input:checked) {
    border-color: var(--color-green);
    background: rgba(121, 184, 42, 0.1);
  }

  .calc-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .calc-option-ui {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    border: 2px solid rgba(121, 184, 42, 0.5);
    position: relative;
  }

  .calc-option:has(input:checked) .calc-option-ui::after {
    content: '';
    position: absolute;
    inset: 0.2rem;
    border-radius: 50%;
    background: var(--color-green);
  }

  .calc-input {
    width: 100%;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    font-size: var(--size-m);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .calc-input:focus {
    outline: none;
    border-color: var(--color-green);
    box-shadow: 0 0 0 3px rgba(121, 184, 42, 0.2);
  }

  .calc-continue {
    width: 100%;
  }

  .calc-consent {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    text-align: left;
    cursor: pointer;
  }

  .calc-consent input {
    margin-top: 0.2rem;
    accent-color: var(--color-green);
  }

  .calc-consent a {
    color: var(--color-green);
    text-decoration: underline;
  }

  .calc-privacy-note {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(121, 184, 42, 0.28);
    border-radius: var(--radius-lg);
    background: rgba(121, 184, 42, 0.1);
    color: var(--color-night);
    text-align: left;
  }

  .calc-nav {
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }

  .calc-back {
    padding: 0.65rem 1.25rem;
  }

  .calc-view--results {
    width: 100%;
    gap: 1.5rem;
    text-align: left;
  }

  .calc-result-card {
    width: 100%;
    padding: 2rem 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--color-surface-soft);
    text-align: center;
  }

  .calc-result-label {
    color: var(--color-green);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .calc-result-percent {
    color: var(--color-night);
    line-height: 1;
  }

  .calc-result-desc {
    color: var(--color-green);
    margin-bottom: 1rem;
  }

  .calc-result-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: #ffffff;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .calc-result-cta-wrap {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .calc-comparison-label {
    width: 100%;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .calc-comparison {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, #ffffff 70%, rgba(121, 184, 42, 0.08));
    border: 1px solid var(--color-border);
  }

  .calc-comparison-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .calc-comparison-bad {
    color: #c0392b;
    margin-top: 0.25rem;
  }

  .calc-comparison-amount {
    font-size: var(--size-headline);
    font-weight: 800;
    color: var(--color-night);
    white-space: nowrap;
  }

  .calc-comparison-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin: 1rem 0;
    padding: 0.5rem;
    border-radius: var(--radius-lg);
    background: rgba(121, 184, 42, 0.15);
    color: var(--color-green);
    font-size: var(--size-xs);
    font-weight: 700;
  }

  .calc-comparison-good {
    color: var(--color-green);
  }

  .calc-comparison-perks {
    list-style: none;
    margin-top: 0.5rem;
    font-size: var(--size-xs);
    color: var(--color-muted);
  }

  .calc-comparison-amount--new {
    color: var(--color-green);
  }

  .calc-why {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .calc-why-x {
    color: #c0392b;
    font-weight: 700;
  }

  .calc-restart {
    align-self: center;
  }

  @media (min-width: 48rem) {
    .calculator-panel {
      max-width: 42rem;
      padding: 3rem 2.5rem;
    }
  }
</style>
