---
import type { Vertical } from '../lib/vertical';

interface Props {
  vertical?: Vertical;
}

const { vertical = 'energy' } = Astro.props;

const allTestimonials = {
  energy: [
    {
      quote: 'Me revisaron la factura de luz y en una llamada entendí por fin qué estaba pagando. El cambio fue sencillo y sin presión.',
      initial: 'M',
      name: 'María G.',
      role: 'Cliente, Madrid',
      tone: 'testimonials__avatar--green',
    },
    {
      quote: 'Tenía luz y gas por separado y pagaba de más. Me propusieron una tarifa clara y ahora ahorro cada mes.',
      initial: 'J',
      name: 'Javier R.',
      role: 'Cliente, Valencia',
      tone: 'testimonials__avatar--gold',
    },
    {
      quote: 'Lo mejor fue no tener que llamar a ninguna compañía de energía. Me explicaron la oferta y ellos gestionaron el cambio.',
      initial: 'L',
      name: 'Laura P.',
      role: 'Cliente, Sevilla',
      tone: 'testimonials__avatar--cream',
    },
  ],
  telecom: [
    {
      quote: 'Pagaba por fibra de 1 Gb y apenas la usaba. Me ajustaron el plan y ahora pago la mitad sin notar diferencia.',
      initial: 'A',
      name: 'Ana S.',
      role: 'Cliente, Barcelona',
      tone: 'testimonials__avatar--green',
    },
    {
      quote: 'Tenía internet, móvil y líneas extra que no usábamos. Me propusieron una alternativa clara y ahora tengo todo controlado.',
      initial: 'J',
      name: 'Javier R.',
      role: 'Cliente, Valencia',
      tone: 'testimonials__avatar--gold',
    },
    {
      quote: 'Lo mejor fue no tener que comparar operadoras. Me explicaron las opciones y ellos gestionaron el cambio sin líos.',
      initial: 'L',
      name: 'Laura P.',
      role: 'Cliente, Sevilla',
      tone: 'testimonials__avatar--cream',
    },
  ],
};

const testimonials = allTestimonials[vertical];
---

<section class="testimonials section" id="testimonios">
  <div class="container">
    <header class="section-header" data-reveal>
      <h2 class="display-xl">Personas que ya ahorran sin líos</h2>
      <p class="body-lg text-muted">Historias reales de hogares que dejaron de pelearse con sus facturas.</p>
    </header>

    <div class="testimonials__grid">
      {testimonials.map((item, i) => (
        <article class="testimonials__card card-lift" data-reveal style={`--reveal-delay: ${i * 100}ms`}>
          <blockquote class="body-md text-muted testimonials__text">"{item.quote}"</blockquote>
          <footer class="testimonials__author">
            <div class={`testimonials__avatar ${item.tone}`}>{item.initial}</div>
            <div>
              <div class="label-s testimonials__name">{item.name}</div>
              <div class="label-xs text-muted-soft">{item.role}</div>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: #ffffff;
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  .testimonials__card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid rgba(226, 226, 222, 0.72);
  }

  .testimonials__text {
    flex: 1;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .testimonials__author {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .testimonials__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    font-weight: 800;
  }

  .testimonials__avatar--green {
    color: #ffffff;
    background: var(--color-green);
  }

  .testimonials__avatar--gold {
    color: var(--color-night);
    background: var(--color-gold);
  }

  .testimonials__avatar--cream {
    color: var(--color-night);
    background: var(--color-cream);
  }

  .testimonials__name {
    color: var(--color-night);
  }

  @media (min-width: 48rem) {
    .testimonials__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
