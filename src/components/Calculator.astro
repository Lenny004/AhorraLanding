---
const benefits = [
  'Porcentaje de ahorro estimado',
  'Ahorro en euros al mes y al año',
  'Mejor tarifa disponible para ti',
];

const householdOptions = ['1 persona', '2 personas', '3 personas', '4 personas', '5 o más'];

const providers = [
  'Iberdrola',
  'Endesa',
  'Naturgy',
  'Repsol',
  'Plenitude (Aldro)',
  'Holaluz',
  'Gana Energía',
  'Otra',
];

const economicOptions = [
  'Llego justo a fin de mes',
  'Cubro gastos y ahorro algo',
  'Vivo con holgura',
  'El dinero no es una preocupación',
];

const livingOptions = [
  'Solo/a',
  'Con mi pareja',
  'Con mi pareja e hijos',
  'Con mis hijos',
  'Con otros familiares',
  'Con compañeros de piso',
];

const crmEndpoint = import.meta.env.PUBLIC_CRM_LANDING_LEADS_ENDPOINT ?? 'https://TU_DOMINIO_CRM/PTR-Sales/api/public/api_landing_leads.php?action=create';
const crmApiKey = import.meta.env.PUBLIC_AHORRA_LANDING_API_KEY ?? '';
---

<section class="calculator section" id="calculadora">
  <div class="container">
    <header class="section-header" data-reveal>
      <h2 class="display-xl">Calculadora</h2>
      <p class="body-lg text-muted">Luz y gas, cuánto puedes ahorrar con la mejor tarifa.</p>
    </header>

    <div
      class="calculator__panel card-lift"
      data-calc-root
      data-endpoint={crmEndpoint}
      data-api-key={crmApiKey}
      data-source="ahorrasinlios"
      data-reveal
    >
      <!-- Intro -->
      <div class="calculator__view" data-calc-view="intro">
        <span class="calculator__badge label-xs">Calculadora gratuita</span>
        <h3 class="calculator__title display-xl">¿Cuánto podrías ahorrar en tu factura de luz?</h3>
        <p class="calculator__lead body-lg text-muted">
          Responde unas preguntas y descubre si estás pagando de más — y qué tarifa te conviene.
        </p>
        <p class="calculator__highlight label-s">
          Ahorro medio: <strong>35€/mes</strong>
        </p>

        <ul class="calculator__benefits">
          {benefits.map((item) => (
            <li class="calculator__benefit">
              <span class="material-symbols-outlined calculator__benefit-icon" aria-hidden="true">check_circle</span>
              {item}
            </li>
          ))}
        </ul>

        <button type="button" class="calculator__cta btn-primary" data-calc-start>
          <span class="calculator__cta-main">Empezar el análisis</span>
          <span class="calculator__cta-sub">Gratis · Sin compromiso · 2 minutos</span>
        </button>
      </div>

      <!-- Wizard -->
      <div class="calculator__view calculator__view--wizard" data-calc-view="wizard" hidden>
        <div class="calculator__progress" aria-hidden="true">
          <div class="calculator__progress-fill" data-calc-progress></div>
        </div>

        <div class="calculator__step" data-calc-step="0">
          <h3 class="calculator__step-title display-xl">¿Qué quieres analizar?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calculator__options" role="radiogroup">
            <label class="calculator__option"><input type="radio" name="serviceType" value="luz" /><span class="calculator__option-ui"></span>Solo luz</label>
            <label class="calculator__option"><input type="radio" name="serviceType" value="luz-gas" /><span class="calculator__option-ui"></span>Luz y gas</label>
          </div>
        </div>

        <div class="calculator__step" data-calc-step="1" hidden>
          <h3 class="calculator__step-title display-xl">¿Cuánto pagas de luz al mes?</h3>
          <p class="calculator__step-sub body-lg text-muted">Mira tu última factura</p>
          <input class="calculator__input" type="number" name="monthlyBill" min="1" placeholder="Ej: 80" inputmode="decimal" />
          <button type="button" class="calculator__continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calculator__step" data-calc-step="2" hidden>
          <h3 class="calculator__step-title display-xl">¿Cuántas personas viven en casa?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calculator__options" role="radiogroup">
            {householdOptions.map((label, i) => (
              <label class="calculator__option">
                <input type="radio" name="householdSize" value={String(i + 1)} />
                <span class="calculator__option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calculator__step" data-calc-step="3" hidden>
          <h3 class="calculator__step-title display-xl">¿Sabes tu potencia contratada?</h3>
          <p class="calculator__step-sub body-lg text-muted">La encontrarás en tu factura de luz</p>
          <div class="calculator__options" role="radiogroup">
            <label class="calculator__option"><input type="radio" name="knowsPower" value="yes" /><span class="calculator__option-ui"></span>Sí, la sé</label>
            <label class="calculator__option"><input type="radio" name="knowsPower" value="no" /><span class="calculator__option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calculator__step" data-calc-step="4" hidden>
          <h3 class="calculator__step-title display-xl">¿Sabes el precio de tu kWh?</h3>
          <p class="calculator__step-sub body-lg text-muted">Lo encontrarás en el detalle de tu factura</p>
          <div class="calculator__options" role="radiogroup">
            <label class="calculator__option"><input type="radio" name="knowsKwh" value="yes" /><span class="calculator__option-ui"></span>Sí, lo sé</label>
            <label class="calculator__option"><input type="radio" name="knowsKwh" value="no" /><span class="calculator__option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calculator__step" data-calc-step="5" hidden>
          <h3 class="calculator__step-title display-xl">¿Qué tipo de tarifa tienes?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción</p>
          <div class="calculator__options" role="radiogroup">
            <label class="calculator__option"><input type="radio" name="tariffType" value="pvpc" /><span class="calculator__option-ui"></span>PVPC (tarifa regulada)</label>
            <label class="calculator__option"><input type="radio" name="tariffType" value="libre" /><span class="calculator__option-ui"></span>Mercado libre</label>
            <label class="calculator__option"><input type="radio" name="tariffType" value="unknown" /><span class="calculator__option-ui"></span>No lo sé</label>
          </div>
        </div>

        <div class="calculator__step" data-calc-step="6" hidden>
          <h3 class="calculator__step-title display-xl">¿Cuál es tu proveedor actual?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calculator__options" role="radiogroup">
            {providers.map((label) => (
              <label class="calculator__option">
                <input type="radio" name="provider" value={label} />
                <span class="calculator__option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calculator__step" data-calc-step="7" hidden>
          <h3 class="calculator__step-title display-xl">¿Cómo describirías tu situación económica actual?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calculator__options" role="radiogroup">
            {economicOptions.map((label) => (
              <label class="calculator__option">
                <input type="radio" name="economicSituation" value={label} />
                <span class="calculator__option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calculator__step" data-calc-step="8" hidden>
          <h3 class="calculator__step-title display-xl">¿Con quién vives?</h3>
          <p class="calculator__step-sub body-lg text-muted">Selecciona una opción *</p>
          <div class="calculator__options" role="radiogroup">
            {livingOptions.map((label) => (
              <label class="calculator__option">
                <input type="radio" name="livingWith" value={label} />
                <span class="calculator__option-ui"></span>
                {label}
              </label>
            ))}
          </div>
        </div>

        <div class="calculator__step" data-calc-step="9" hidden>
          <h3 class="calculator__step-title display-xl">¿Cuál es tu código postal?</h3>
          <p class="calculator__step-sub body-lg text-muted">Introduce tu código postal *</p>
          <input class="calculator__input" type="text" name="postalCode" placeholder="Ej: 28001" maxlength="5" inputmode="numeric" pattern="[0-9]{5}" />
          <button type="button" class="calculator__continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calculator__step" data-calc-step="10" hidden>
          <h3 class="calculator__step-title display-xl">¿Cómo te llamas?</h3>
          <p class="calculator__step-sub body-lg text-muted">Introduce tu nombre completo *</p>
          <p class="calculator__privacy-note body-md">
            Para enviarte el resultado personalizado, necesitamos tu contacto. Solo guardaremos tus datos en nuestro CRM si aceptas la política de privacidad.
          </p>
          <input class="calculator__input" type="text" name="firstName" placeholder="Nombre" autocomplete="given-name" />
          <input class="calculator__input" type="text" name="lastName" placeholder="Introduce tu apellido" autocomplete="family-name" />
          <button type="button" class="calculator__continue btn-primary" data-calc-next>Continuar</button>
        </div>

        <div class="calculator__step" data-calc-step="11" hidden>
          <h3 class="calculator__step-title display-xl">¿Cuál es tu número de teléfono?</h3>
          <p class="calculator__step-sub body-lg text-muted">Introduce tu teléfono *</p>
          <input class="calculator__input" type="tel" name="phone" placeholder="600 00 00 00" autocomplete="tel" />
          <label class="calculator__consent">
            <input type="checkbox" name="privacy" />
            <span class="body-md text-muted">
              Acepto que Ahorra Sin Líos trate mis datos personales y los registre para contactarme con la mejor oferta energética. Puedo retirar mi consentimiento en cualquier momento. <a href="/privacidad">Política de privacidad</a>.
            </span>
          </label>
          <button type="button" class="calculator__continue btn-primary" data-calc-finish>Continuar</button>
        </div>

        <div class="calculator__nav">
          <button type="button" class="calculator__back btn-secondary" data-calc-back hidden>
            <span class="material-symbols-outlined" aria-hidden="true">arrow_back</span>
            Atrás
          </button>
        </div>
      </div>

      <!-- Results -->
      <div class="calculator__view calculator__view--results" data-calc-view="results" hidden>
        <div class="calculator__result-card">
          <p class="calculator__result-label label-xs">Resultado del análisis</p>
          <p class="calculator__result-percent display-xl" data-calc-result-percent>35%</p>
          <p class="calculator__result-desc body-lg">de ahorro estimado en tu factura</p>
          <p class="calculator__result-badge label-s" data-calc-result-savings>28,00€/mes · 336,00€/año</p>

          <div class="calculator__result-cta-wrap">
            <p class="body-md text-muted">Encuentra la tarifa que mejor encaja contigo hoy</p>
            <a href="#contacto" class="calculator__cta btn-primary" data-calc-result-cta>
              <span class="calculator__cta-main">Quiero pagar menos →</span>
              <span class="calculator__cta-sub">Gratis · Sin compromiso · 5 minutos</span>
            </a>
          </div>
        </div>

        <p class="calculator__comparison-label label-xs text-muted-soft">Factura de luz</p>
        <div class="calculator__comparison card-lift">
          <div class="calculator__comparison-row">
            <div>
              <p class="label-xs text-muted-soft">Pagas ahora</p>
              <p class="calculator__comparison-bad label-xs">✕ Tarifa sin optimizar</p>
            </div>
            <p class="calculator__comparison-amount" data-calc-result-current>80,00€</p>
          </div>
          <div class="calculator__comparison-bar">
            <span class="material-symbols-outlined" aria-hidden="true">south</span>
            Cambiando de tarifa
          </div>
          <div class="calculator__comparison-row calculator__comparison-row--new">
            <div>
              <p class="label-s calculator__comparison-good">Tu nueva factura</p>
              <ul class="calculator__comparison-perks">
                <li>✓ Potencia optimizada</li>
                <li>✓ Mejor tarifa del mercado</li>
                <li>✓ Sin permanencia</li>
              </ul>
            </div>
            <p class="calculator__comparison-amount calculator__comparison-amount--new" data-calc-result-new>52,00€</p>
          </div>
        </div>

        <p class="calculator__comparison-label label-xs text-muted-soft">Por qué estás pagando de más</p>
        <div class="calculator__why card-lift">
          <p class="body-md"><span class="calculator__why-x" aria-hidden="true">✕</span> <strong>Tu comercializadora nunca te llamará</strong> para ofrecerte una tarifa más barata — no es su interés.</p>
          <p class="body-md"><span class="calculator__why-x" aria-hidden="true">✕</span> <strong>Las mejores tarifas no se publicitan.</strong> Hay que saber dónde buscarlas y negociarlas.</p>
        </div>

        <button type="button" class="calculator__restart btn-secondary" data-calc-restart>Volver a calcular</button>
      </div>
    </div>
  </div>
</section>

<script>
  import { initEnergyCalculator } from '../scripts/energy-calculator';

  initEnergyCalculator();
</script>

<style>
  .calculator {
    scroll-margin-top: 5rem;
    background: var(--color-bg);
  }

  .calculator__panel {
    max-width: 36rem;
    margin-inline: auto;
    padding: 2.5rem 2rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid rgba(226, 226, 222, 0.72);
    text-align: center;
  }

  .calculator__view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .calculator__view[hidden],
  .calculator__step[hidden] {
    display: none;
  }

  .calculator__badge {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-full);
    border: 1px solid rgba(121, 184, 42, 0.45);
    color: var(--color-green);
    background: rgba(121, 184, 42, 0.08);
  }

  .calculator__title {
    font-size: calc(var(--size-xl) * 0.72);
  }

  .calculator__lead {
    max-width: 28rem;
  }

  .calculator__highlight {
    color: var(--color-green);
  }

  .calculator__benefits {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    list-style: none;
  }

  @media (min-width: 40rem) {
    .calculator__benefits {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  .calculator__benefit {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-soft);
    font-size: var(--size-xs);
    font-weight: 600;
    text-align: left;
  }

  .calculator__benefit-icon {
    font-size: 1.25rem;
    color: var(--color-green);
  }

  .calculator__cta {
    flex-direction: column;
    width: 100%;
    padding-block: 1.1rem;
    gap: 0.25rem;
  }

  .calculator__cta-main {
    font-size: var(--size-s);
    font-weight: 700;
  }

  .calculator__cta-sub {
    font-size: var(--size-xs);
    font-weight: 500;
    opacity: 0.9;
  }

  .calculator__view--wizard {
    width: 100%;
    gap: 2rem;
  }

  .calculator__progress {
    width: 100%;
    height: 0.25rem;
    border-radius: var(--radius-full);
    background: var(--color-surface-soft);
    overflow: hidden;
  }

  .calculator__progress-fill {
    height: 100%;
    width: 0;
    border-radius: inherit;
    background: var(--color-green);
    transition: width 0.35s ease;
  }

  .calculator__step {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 1.25rem;
    width: 100%;
  }

  .calculator__step-title {
    font-size: calc(var(--size-xl) * 0.65);
    text-align: center;
  }

  .calculator__step-sub {
    text-align: center;
    margin-top: -0.5rem;
  }

  .calculator__options {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .calculator__option {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(121, 184, 42, 0.35);
    background: #ffffff;
    cursor: pointer;
    font-weight: 600;
    text-align: left;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .calculator__option:hover {
    border-color: var(--color-green);
  }

  .calculator__option:has(input:checked) {
    border-color: var(--color-green);
    background: rgba(121, 184, 42, 0.1);
  }

  .calculator__option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  .calculator__option-ui {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    border: 2px solid rgba(121, 184, 42, 0.5);
    position: relative;
  }

  .calculator__option:has(input:checked) .calculator__option-ui::after {
    content: '';
    position: absolute;
    inset: 0.2rem;
    border-radius: 50%;
    background: var(--color-green);
  }

  .calculator__input {
    width: 100%;
    padding: 1rem 1.15rem;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    font-size: var(--size-m);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .calculator__input:focus {
    outline: none;
    border-color: var(--color-green);
    box-shadow: 0 0 0 3px rgba(121, 184, 42, 0.2);
  }

  .calculator__continue {
    width: 100%;
  }

  .calculator__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    text-align: left;
    cursor: pointer;
  }

  .calculator__consent input {
    margin-top: 0.2rem;
    accent-color: var(--color-green);
  }

  .calculator__consent a {
    color: var(--color-green);
    text-decoration: underline;
  }

  .calculator__privacy-note {
    padding: 0.9rem 1rem;
    border: 1px solid rgba(121, 184, 42, 0.28);
    border-radius: var(--radius-lg);
    background: rgba(121, 184, 42, 0.1);
    color: var(--color-night);
    text-align: left;
  }

  .calculator__nav {
    width: 100%;
    display: flex;
    justify-content: flex-start;
  }

  .calculator__back {
    padding: 0.65rem 1.25rem;
  }

  .calculator__view--results {
    width: 100%;
    gap: 1.5rem;
    text-align: left;
  }

  .calculator__result-card {
    width: 100%;
    padding: 2rem 1.5rem;
    border-radius: var(--radius-xl);
    background: var(--color-surface-soft);
    text-align: center;
  }

  .calculator__result-label {
    color: var(--color-green);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .calculator__result-percent {
    color: var(--color-night);
    line-height: 1;
  }

  .calculator__result-desc {
    color: var(--color-green);
    margin-bottom: 1rem;
  }

  .calculator__result-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-border);
    background: #ffffff;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .calculator__result-cta-wrap {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .calculator__comparison-label {
    width: 100%;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .calculator__comparison {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, #ffffff 70%, rgba(121, 184, 42, 0.08));
    border: 1px solid var(--color-border);
  }

  .calculator__comparison-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
  }

  .calculator__comparison-bad {
    color: #c0392b;
    margin-top: 0.25rem;
  }

  .calculator__comparison-amount {
    font-size: var(--size-headline);
    font-weight: 800;
    color: var(--color-night);
    white-space: nowrap;
  }

  .calculator__comparison-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    margin: 1rem 0;
    padding: 0.5rem;
    border-radius: var(--radius-lg);
    background: rgba(121, 184, 42, 0.15);
    color: var(--color-green);
    font-size: var(--size-xs);
    font-weight: 700;
  }

  .calculator__comparison-good {
    color: var(--color-green);
  }

  .calculator__comparison-perks {
    list-style: none;
    margin-top: 0.5rem;
    font-size: var(--size-xs);
    color: var(--color-muted);
  }

  .calculator__comparison-amount--new {
    color: var(--color-green);
  }

  .calculator__why {
    width: 100%;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: #ffffff;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .calculator__why-x {
    color: #c0392b;
    font-weight: 700;
  }

  .calculator__restart {
    align-self: center;
  }

  @media (min-width: 48rem) {
    .calculator__panel {
      max-width: 42rem;
      padding: 3rem 2.5rem;
    }
  }
</style>
