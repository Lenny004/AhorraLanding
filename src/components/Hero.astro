---
import type { Vertical } from '../lib/vertical';

interface Props {
  vertical?: Vertical;
}

const { vertical = 'energy' } = Astro.props;

const copy = {
  energy: {
    kicker: 'Elige tranquilidad',
    title: 'Ahorra en luz y gas',
    titleAccent: 'sin pelearte con las compañías.',
    lead: 'Comparamos tarifas de luz y gas por ti. Te explicamos las opciones en claro y gestionamos el cambio sin líos, sin coste y sin compromiso.',
    billTitle: 'Factura revisada',
    billText: 'Detectamos oportunidades reales de ahorro en energía.',
  },
  telecom: {
    kicker: 'Conecta sin pagar de más',
    title: 'Ahorra en móvil e internet',
    titleAccent: 'con el plan que realmente necesitas.',
    lead: 'Comparamos fibra y tarifas móviles por ti. Sin servicios añadidos que encarecen la factura, sin líos y sin compromiso.',
    billTitle: 'Tarifa revisada',
    billText: 'Detectamos si pagas de más en fibra o datos móviles.',
  },
}[vertical];

const metrics = [
  { value: '+15.000', label: 'Familias asesoradas' },
  { value: '44%', label: 'Ahorro medio anual' },
  { value: '100%', label: 'Gratuito y sin compromiso' },
];

const heroImage =
  'https://lh3.googleusercontent.com/aida-public/AB6AXuDmDB6HNeJWpIdsT5_LRrfZWfBR8I1YOHUIqfJhjOnA9Vdyia9PQFIpp3gmZIreoTrv6OnhAYgfvfw7s-kcIzGrnT0iTuo08iwzIxW_2WU5V84rv6zHHiXMLf6Fk2RFCh_KeG2XYd2FMXHKNuoe4X1PcVn0k_7d_dNVXeWVvpvBRwrS5HONn9f8BOZ_jld7bRSuJukWEWqGxYnlR3ZpIbBCBd_2CJn-uIT1j1FJVeosAlJlIV0gnqOMQK9GeRWR9p6Dsv8';
---

<section class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__bg-blob hero__bg-blob--top"></div>
    <div class="hero__bg-blob hero__bg-blob--bottom"></div>
  </div>

  <div class="container">
    <div class="hero__grid">
      <div class="hero__content" data-reveal>
        <span class="label-s hero__kicker">{copy.kicker}</span>
        <h1 class="display-xl">
          {copy.title} <span class="text-gradient">{copy.titleAccent}</span>
        </h1>
        <p class="body-lg text-muted hero__lead">
          {copy.lead}
        </p>

        <div class="hero__actions">
          <a href="#contacto" class="btn-primary">
            <span class="material-symbols-outlined hero__action-icon" aria-hidden="true">attach_money</span>
            Quiero que revisen mi factura
          </a>
          <a href="#como-funciona" class="btn-secondary">Ver cómo funciona</a>
        </div>

        <div class="hero__metrics">
          {metrics.map((metric, i) => (
            <div class="hero__metric" data-reveal style={`--reveal-delay: ${(i + 1) * 100}ms`}>
              <div class="headline-lg hero__metric-value" data-count={metric.value}>{metric.value}</div>
              <div class="label-xs text-muted-soft hero__metric-label">{metric.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero__visual" data-reveal style="--reveal-delay: 150ms">
        <div class="hero__card hero__card--bill glass-panel">
          <div class="hero__card-icon hero__card-icon--light">
            <span class="material-symbols-outlined">receipt_long</span>
          </div>
          <h3 class="label-s hero__card-title">{copy.billTitle}</h3>
          <p class="label-xs text-muted">{copy.billText}</p>
        </div>

        <div class="hero__card hero__card--saving">
          <div class="hero__saving-header">
            <div class="hero__card-icon hero__card-icon--dark">
              <span class="material-symbols-outlined">trending_down</span>
            </div>
            <div>
              <div class="label-xs hero__saving-label">Ahorro estimado</div>
              <div class="headline-lg hero__saving-value">300€</div>
            </div>
          </div>
          <div class="hero__saving-bars" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
        </div>

        <div class="hero__image-wrap">
          <img class="hero__image" src={heroImage} alt="Hucha verde junto a una factura y monedas" loading="eager" />
          <div class="hero__image-overlay"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { initHeroCounter } from '../scripts/hero-counter';

  initHeroCounter();
</script>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: 6rem 8rem;
    background: var(--color-bg);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero__bg-blob {
    position: absolute;
    border-radius: var(--radius-full);
    filter: blur(4rem);
    opacity: 0.55;
  }

  .hero__bg-blob--top {
    top: -10%;
    right: -8%;
    width: 55%;
    height: 80%;
    background: linear-gradient(to bottom left, rgba(121, 184, 42, 0.18), transparent);
  }

  .hero__bg-blob--bottom {
    bottom: -8%;
    left: -8%;
    width: 48%;
    height: 50%;
    background: linear-gradient(to top right, rgba(231, 184, 46, 0.22), transparent);
  }

  .hero__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero__kicker {
    width: fit-content;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-full);
    color: var(--color-night);
    background: var(--color-cream);
    border: 1px solid var(--color-border);
  }

  .hero__lead {
    max-width: 38rem;
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 0.5rem;
  }

  .hero__action-icon {
    font-size: var(--size-m);
    font-variation-settings: 'FILL' 1;
  }

  .hero__metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .hero__metric {
    transition: transform 0.3s ease;
  }

  .hero__metric:hover {
    transform: translateY(-0.125rem);
  }

  .hero__metric-value {
    color: var(--color-night);
    font-variant-numeric: tabular-nums;
  }

  .hero__visual {
    position: relative;
    height: 37.5rem;
    width: 100%;
    max-width: 36rem;
    margin-inline: auto;
  }

  .hero__card {
    position: absolute;
    border-radius: var(--radius-xl);
    z-index: 20;
  }

  .hero__card--bill {
    top: 2.5rem;
    right: 0;
    width: 16rem;
    padding: 1.5rem;
    box-shadow: var(--shadow-soft);
    animation: hero__float 4s ease-in-out infinite;
  }

  .hero__card--saving {
    bottom: 5rem;
    left: 0;
    width: 18rem;
    padding: 1.5rem;
    color: #ffffff;
    background: var(--color-night);
    box-shadow: var(--shadow-lift);
    z-index: 30;
    animation: hero__float 5s ease-in-out infinite;
  }

  .hero__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
  }

  .hero__card-icon--light {
    width: 3rem;
    height: 3rem;
    margin-bottom: 1rem;
    color: var(--color-gold);
    background: var(--color-cream);
  }

  .hero__card-icon--dark {
    width: 2.5rem;
    height: 2.5rem;
    color: #ffffff;
    background: rgba(255, 255, 255, 0.1);
  }

  .hero__card-icon .material-symbols-outlined {
    font-size: var(--size-lg);
  }

  .hero__card-title {
    margin-bottom: 0.25rem;
    color: var(--color-night);
  }

  .hero__saving-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .hero__saving-label {
    color: rgba(255, 255, 255, 0.68);
  }

  .hero__saving-value {
    color: var(--color-green);
  }

  .hero__saving-bars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
    align-items: end;
    height: 4rem;
  }

  .hero__saving-bars span {
    display: block;
    border-radius: var(--radius-full) var(--radius-full) 0 0;
    background: linear-gradient(to top, var(--color-green), var(--color-gold));
    opacity: 0.85;
  }

  .hero__saving-bars span:nth-child(1) { height: 45%; }
  .hero__saving-bars span:nth-child(2) { height: 65%; }
  .hero__saving-bars span:nth-child(3) { height: 82%; }
  .hero__saving-bars span:nth-child(4) { height: 100%; }

  .hero__image-wrap {
    position: absolute;
    top: 5rem;
    left: 50%;
    translate: -50% 0;
    width: 80%;
    height: calc(100% - 5rem);
    border-radius: var(--radius-brand);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(21, 23, 27, 0.66), transparent);
    mix-blend-mode: multiply;
  }

  @keyframes hero__float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-0.625rem);
    }
  }

  @media (min-width: 40rem) {
    .hero__actions {
      flex-direction: row;
    }
  }

  @media (min-width: 64rem) {
    .hero__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }
</style>
