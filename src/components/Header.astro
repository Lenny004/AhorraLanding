---
import Brand from './Brand.astro';
import type { Vertical } from '../lib/vertical';
import { verticalLabels, verticalPaths } from '../lib/vertical';

interface Props {
  vertical?: Vertical;
}

const { vertical = 'energy' } = Astro.props;

const otherVertical: Vertical = vertical === 'energy' ? 'telecom' : 'energy';

const navLinks = [
  { href: '#comparativa', label: 'Comparativa' },
  { href: '#servicios', label: 'Servicios' },
  { href: '#como-funciona', label: 'Cómo funciona' },
  { href: '#testimonios', label: 'Opiniones' },
  { href: '#calculadora', label: 'Calculadora' },
  { href: verticalPaths[otherVertical], label: verticalLabels[otherVertical] },
];
---

<header class="site-header" data-header>
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Ahorra Sin Líos">
      <Brand />
    </a>

    <nav class="site-header__nav" aria-label="Principal">
      {navLinks.map((link) => (
        <a href={link.href} class="site-header__link">{link.label}</a>
      ))}
    </nav>

    <a href="#contacto" class="site-header__cta">Contactar</a>

    <button
      type="button"
      class="site-header__toggle"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <span class="material-symbols-outlined site-header__toggle-icon" data-menu-icon>menu</span>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="site-header__menu"
    data-mobile-menu
    aria-label="Menú móvil"
    hidden
  >
    {navLinks.map((link) => (
      <a href={link.href} class="site-header__menu-link">{link.label}</a>
    ))}
    <a href="#contacto" class="site-header__menu-cta">Contactar</a>
  </nav>
</header>

<script>
  import { initSiteHeader } from '../scripts/site-header';

  initSiteHeader();
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(247, 247, 244, 0.92);
    backdrop-filter: blur(0.75rem);
    border-bottom: 1px solid rgba(226, 226, 222, 0.72);
    box-shadow: var(--shadow-soft);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1rem;
  }

  .site-header__nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }

  .site-header__link {
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .site-header__link:hover {
    color: var(--color-night);
  }

  .site-header__cta {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-xl);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #ffffff;
    background: var(--color-night);
    transition: background-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .site-header__cta:hover {
    background: var(--color-green);
    transform: translateY(-0.125rem);
    box-shadow: var(--shadow-soft);
  }

  .site-header__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem;
    border: none;
    background: transparent;
    color: var(--color-night);
    cursor: pointer;
  }

  .site-header__toggle-icon {
    font-size: var(--size-icon-nav);
  }

  .site-header__menu {
    display: none;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem var(--gutter) 1.25rem;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .site-header__menu--open {
    display: flex;
  }

  .site-header__menu-link {
    padding: 0.75rem 0;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }

  .site-header__menu-link:hover {
    color: var(--color-night);
  }

  .site-header__menu-cta {
    margin-top: 0.5rem;
    padding: 0.8rem 1.5rem;
    border-radius: var(--radius-xl);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: center;
    color: #ffffff;
    background: var(--color-night);
    transition: background-color 0.2s ease;
  }

  .site-header__menu-cta:hover {
    background: var(--color-green);
  }

  @media (min-width: 769px) {
    .site-header__nav,
    .site-header__cta {
      display: flex;
      flex-wrap: wrap;
    }

    .site-header__toggle {
      display: none;
    }

    .site-header__menu {
      display: none !important;
    }
  }

  @media (max-width: 30rem) {
    .brand img {
      height: 2.5rem;
    }
  }
</style>
